// prisma/schema.prisma
// FintechWallet v2 — Prisma schema for MySQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ── User ─────────────────────────────────────────────────────
model User {
  id              Int       @id @default(autoincrement()) @db.UnsignedInt
  fullname        String    @db.VarChar(150)
  email           String    @unique @db.VarChar(150)
  phone           String    @unique @db.VarChar(20)
  password        String    @db.VarChar(255)
  bvn             String?   @db.VarChar(20)
  role            Role      @default(USER)
  isFrozen        Boolean   @default(false) @map("is_frozen")
  isVerified      Boolean   @default(false) @map("is_verified")
  transactionPin  String?   @map("transaction_pin") @db.VarChar(255)
  pinSet          Boolean   @default(false) @map("pin_set")
  lastLoginAt     DateTime? @map("last_login_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  wallet          Wallet?
  account         BankAccount?
  transactions    Transaction[]
  sessions        Session[]
  adminLogs       AdminLog[]    @relation("AdminUser")
  otps            OTP[]

  @@map("users")
}

enum Role {
  USER
  ADMIN
}

// ── Wallet ───────────────────────────────────────────────────
model Wallet {
  id        Int      @id @default(autoincrement()) @db.UnsignedInt
  userId    Int      @unique @map("user_id") @db.UnsignedInt
  balance   Decimal  @default(0.00) @db.Decimal(15, 2)
  currency  String   @default("NGN") @db.VarChar(10)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("wallets")
}

// ── Bank Account ─────────────────────────────────────────────
model BankAccount {
  id            Int      @id @default(autoincrement()) @db.UnsignedInt
  userId        Int      @unique @map("user_id") @db.UnsignedInt
  accountNumber String   @unique @map("account_number") @db.VarChar(20)
  accountName   String   @map("account_name") @db.VarChar(150)
  bankName      String   @map("bank_name") @db.VarChar(100)
  bankCode      String?  @map("bank_code") @db.VarChar(10)
  createdAt     DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("bank_accounts")
}

// ── Transaction ───────────────────────────────────────────────
model Transaction {
  id          Int               @id @default(autoincrement()) @db.UnsignedInt
  userId      Int               @map("user_id") @db.UnsignedInt
  type        TransactionType
  amount      Decimal           @db.Decimal(15, 2)
  status      TransactionStatus @default(PENDING)
  reference   String            @unique @db.VarChar(100)
  description String?           @db.VarChar(255)
  meta        Json?
  ipAddress   String?           @map("ip_address") @db.VarChar(45)
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@map("transactions")
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  TRANSFER_OUT
  TRANSFER_IN
  AIRTIME
  DATA
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

// ── OTP / Verification Tokens ─────────────────────────────────
model OTP {
  id        Int      @id @default(autoincrement()) @db.UnsignedInt
  userId    Int      @map("user_id") @db.UnsignedInt
  code      String   @db.VarChar(6)
  type      OTPType
  token     String?  @unique @db.VarChar(100)
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("otps")
}

enum OTPType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

// ── Session ───────────────────────────────────────────────────
model Session {
  id         Int      @id @default(autoincrement()) @db.UnsignedInt
  userId     Int      @map("user_id") @db.UnsignedInt
  tokenHash  String   @map("token_hash") @db.VarChar(64)
  device     String?  @db.VarChar(255)
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  isRevoked  Boolean  @default(false) @map("is_revoked")
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@map("sessions")
}

// ── Admin Log ─────────────────────────────────────────────────
model AdminLog {
  id         Int      @id @default(autoincrement()) @db.UnsignedInt
  adminId    Int      @map("admin_id") @db.UnsignedInt
  targetType String   @map("target_type") @db.VarChar(50)
  targetId   Int?     @map("target_id") @db.UnsignedInt
  action     String   @db.VarChar(100)
  detail     Json?
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  createdAt  DateTime @default(now()) @map("created_at")

  admin User @relation("AdminUser", fields: [adminId], references: [id], onDelete: Cascade)

  @@map("admin_logs")
}

// ── Webhook Log ───────────────────────────────────────────────
model WebhookLog {
  id          Int      @id @default(autoincrement()) @db.UnsignedInt
  provider    String?  @db.VarChar(50)
  reference   String?  @db.VarChar(100)
  eventType   String?  @map("event_type") @db.VarChar(100)
  payload     Json?
  status      String   @default("received") @db.VarChar(50)
  errorMsg    String?  @map("error_msg") @db.Text
  processedAt DateTime? @map("processed_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("webhook_logs")
}
